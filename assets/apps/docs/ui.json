{
  "app": {
    "title": "Docs",
    "primaryColor": "#00897B",
    "theme": "paper"
  },
  "nav": [
    { "id": "pages", "label": "Pages", "icon": "menu_book", "screen": "pages" },
    { "id": "all", "label": "All", "icon": "list", "screen": "all" }
  ],
  "screens": {
    "pages": {
      "title": "Pages",
      "body": {
        "type": "column",
        "children": [
          {
            "type": "text",
            "style": "caption",
            "value": "Your document tree. Tap a page to open and edit its rich text; tap the + on a page to add a child page (sub-tab); drag-hold a page to re-nest it."
          },
          {
            "type": "button",
            "label": "New page",
            "icon": "add",
            "action": {
              "fn": "addRow",
              "args": { "table": "pages", "values": { "title": "Untitled" } }
            }
          },
          {
            "type": "tree",
            "table": "pages",
            "parentColumn": "parentId",
            "titleColumn": "title",
            "orderColumn": "order",
            "action": { "fn": "editRow" },
            "addChild": true,
            "reorder": "hold",
            "holdMs": 600,
            "filterable": true
          }
        ]
      }
    },
    "all": {
      "title": "All pages",
      "body": {
        "type": "column",
        "children": [
          {
            "type": "text",
            "style": "caption",
            "value": "A flat list of every page, newest edit first. Tap to open."
          },
          {
            "type": "button",
            "label": "New page",
            "icon": "add",
            "action": {
              "fn": "addRow",
              "args": { "table": "pages", "values": { "title": "Untitled" } }
            }
          },
          {
            "type": "table",
            "table": "pages",
            "columns": ["title", "updatedAt"],
            "sort": { "column": "updatedAt", "dir": "desc" },
            "action": { "fn": "editRow" }
          }
        ]
      }
    }
  }
}
